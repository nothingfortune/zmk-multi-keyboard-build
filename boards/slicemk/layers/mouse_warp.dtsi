/* slicemk — LAYER 17: Mouse Warp */

        LAYER_MouseWarp {
			bindings = <
			/* Row 0 */
				&none
			/* Row 1 */
				&trans                                     &trans                                  &trans                                  &trans                                  &trans                                 &trans                                                                       &trans                    &trans                  &trans                                    &trans                                &trans                                    &trans                                 &trans                                     &trans
			/* Row 2 */
				&trans                                     &trans                                  &trans                                   &trans                                  &trans                                 &trans                                                                        &kp C_PLAY_PAUSE                &kp C_VOL_UP                    &trans                                       &trans                                &trans                                  &trans                                 &trans                                     &trans
			/* Row 3 */
				&trans                                     &trans                                  &trans                                  &trans                                  &trans                                 &trans                                                                        &trans                                   &trans                                &trans                                   &trans                                 &trans                                     &trans
			/* Row 4 */
				&magic LAYER_Magic 0                              &trans                                  &trans                                  &trans                                  &trans                                 &trans                                                                        &kp C_NEXT                      &kp C_VOL_DN                    &trans                                       &trans                                &trans                                   &trans                                 &trans                                     &trans
			/* Row 5 */
				&kp LCTRL                           &trans                                  &trans                                  &trans                                                                                                                                                        &mkp RCLK                                                                                                                                   &arrow_left LC(LEFT) LEFT                   &trans                                &trans                                    &trans    &hyper_key

			/* Thumb Cluster - Top Pair */
				&kp DEL                             &trans                     &kp C_NEXT                      &kp DEL
			/* Thumb Cluster - Left to Right*/
				&trans                                  &trans                                 &trans                                                                       &trans                                    &trans                                &trans
			/* Inside Thumb Cluster */
				&lt LAYER_Keypad QUESTION            &lt LAYER_Symbol PERIOD
			>;
		};