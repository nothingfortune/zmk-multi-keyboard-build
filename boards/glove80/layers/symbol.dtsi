/* glove80 — LAYER_Symbol (row-interleaved; shared positions synced from boards/go60/layers/symbol.dtsi) */

        LAYER_Symbol {
            bindings = <

/* ── Row 0 — function row (glove80-only) ─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────── */
