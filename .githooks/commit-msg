#!/usr/bin/env bash
set -euo pipefail

msg_file="$1"

# Strip commit trailers that attribute authorship to local coding tools.
# This keeps the hook narrow: it only removes Co-authored-by lines for the
# assistant names used in this repo workflow, and leaves other trailers alone.
perl -0pi -e '
  s/^[ \t]*Co-authored-by:\s*(?:Claude(?: Code)?|GitHub Copilot|Copilot)\b[^\n]*\n?//gmi;
  s/\n{3,}/\n\n/g;
  s/\n+\z/\n/;
' "$msg_file"